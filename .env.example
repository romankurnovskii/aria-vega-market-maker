# Aria Vega — Market Maker Configurations

# Core Solana Settings
# WALLET_PUBKEY: Your operational Solana wallet public address
WALLET_PUBKEY=

# PRIVATE_KEY_BASE64: Base64-encoded 64-byte Solana wallet secret key.
# 
# HOW TO GET THIS VALUE:
# 1. From Phantom / Solflare wallet: Go to Settings -> Export Private Key (gives a Base58 string).
# 2. From Solana CLI: Locate your keypair file (e.g., ~/.config/solana/id.json, a JSON array of 64 numbers).
# 3. Run the helper conversion script from the root of this project:
#    node .dev/to-base64.js <your-base58-key-or-json-array-or-file>
# 4. Copy the resulting Base64 string and paste it below.
PRIVATE_KEY_BASE64=

# Node/Engine Operational Settings
PORT=3000
TICK_INTERVAL_MS=10000

# RPC Connection Endpoints
SOLANA_URL=
HELIUS_URL=
